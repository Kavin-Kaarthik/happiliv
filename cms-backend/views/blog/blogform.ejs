<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog Form</title>

    <%- include("../partials/links") -%>

        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jodit@4.2.39/es2021/jodit.min.css" />
</head>

<body>

    <div class="page-layout">

        <%- include("../partials/header") -%>
            <%- include("../partials/sidebar") -%>
                <main class="app-wrapper">
                    <div class="container-fluid">

                        <div class="app-page-head d-flex align-items-center justify-content-between">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-0">
                                    <li class="breadcrumb-item">
                                        <a href="/"><i class="fi fi-rr-home"></i> Home</a>
                                    </li>
                                    <li class="icon-size"><i class="fa-solid fa-chevron-right"></i></li>
                                    <li class="breadcrumb-item active" aria-current="page">Blog Form</li>
                                </ol>
                            </nav>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <div class="card card-body">
                                    <% let currentErrors=(typeof errors !=='undefined' ) ? errors : {}; let
                                        currentOld=(typeof old !=='undefined' ) ? old : {}; let currentTag=(typeof tag
                                        !=='undefined' ) ? tag : null; let actionUrl="/api/blog/create" ; let
                                        buttonText="Add" ; if (currentTag && currentTag.id) {
                                        actionUrl="/api/blog/update/" + currentTag.id; buttonText="Update" ; } %>

                                        <form class="row" id="blogForm" action="<%= actionUrl %>" method="post"
                                            enctype="multipart/form-data">

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Meta Title</label>
                                                <input type="text" name="metaTitle" class="form-control"
                                                    placeholder="Enter meta title"
                                                    value="<%= currentOld.metaTitle || '' %>">
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Meta Keyword</label>
                                                <input type="text" name="metaKeyword" class="form-control"
                                                    placeholder="Keywords (comma separated)"
                                                    value="<%= currentOld.metaKeyword || '' %>">
                                            </div>

                                            <div class="col-lg-12 mb-3">
                                                <label class="form-label">Meta Description</label>
                                                <textarea name="metaDesc" class="form-control"
                                                    rows="2"><%= currentOld.metaDesc || '' %></textarea>
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Slug <span
                                                        class="text-danger">*</span></label>
                                                <input type="text" name="slug" id="blogSlug" class="form-control"
                                                    placeholder="blog-post-url-slug"
                                                    value="<%= currentOld.slug || '' %>" required>
                                                <% if (currentErrors.slug) { %> <small class="text-danger">
                                                        <%= currentErrors.slug %>
                                                    </small>
                                                    <% } %>
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Og Title</label>
                                                <input type="text" name="ogTitle" class="form-control"
                                                    placeholder="Open graph title"
                                                    value="<%= currentOld.ogTitle || '' %>">
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">OG Image</label>
                                                <% if (currentTag && (currentTag.ogImagePreview || currentTag.ogImage))
                                                    { %>
                                                    <div id="ogImage-preview-wrapper" class="mb-2">
                                                        <div class="position-relative d-inline-block">
                                                            <% let ogImagePath=currentTag.ogImage.includes('http') ?
                                                                currentTag.ogImage :
                                                                `/data/uploads/blogs/${currentTag.ogImage}`; %>
                                                                <img src="<%= ogImagePath %>" class="rounded border"
                                                                    style="width: 150px; height: 100px; object-fit: cover;">
                                                                <button type="button"
                                                                    class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1"
                                                                    onclick="handleImageDelete('ogImage')">
                                                                    <i class="fa-solid fa-trash-can"></i>
                                                                </button>
                                                        </div>
                                                    </div>
                                                    <% } %>
                                                        <div id="ogImage-file-input-wrapper"
                                                            style="<%= (currentTag && (currentTag.ogImagePreview || currentTag.ogImage)) ? 'display: none;' : '' %>">
                                                            <input class="form-control" type="file" name="ogImage"
                                                                id="ogImage">
                                                            <input type="hidden" name="ogImageRemoved"
                                                                id="ogImageRemoved" value="false">
                                                        </div>
                                                        <% if (currentErrors.ogImage) { %>
                                                            <small class="text-danger">
                                                                <%= currentErrors.ogImage %>
                                                            </small>
                                                            <% } %>
                                            </div>
                                            <div class="col-lg-12 mb-3">
                                                <label class="form-label">Og Description</label>
                                                <textarea name="ogDesc" class="form-control"
                                                    rows="2"><%= currentOld.ogDesc || '' %></textarea>
                                            </div>

                                            <hr class="my-4">

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Blog Name <span
                                                        class="text-danger">*</span></label>
                                                <input type="text" name="blogName" id="blogName" class="form-control"
                                                    placeholder="Enter blog name"
                                                    value="<%= currentOld.blogName || '' %>" required>
                                                <% if (currentErrors.blogName) { %> <small class="text-danger">
                                                        <%= currentErrors.blogName %>
                                                    </small>
                                                    <% } %>
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Banner Image<span
                                                        class="text-danger">*</span></label>
                                                <% if (currentTag && currentTag.bannerImage) { %>
                                                    <div id="bannerImage-preview-wrapper" class="mb-2">
                                                        <div class="position-relative d-inline-block">
                                                            <% let bannerPath=currentTag.bannerImage.includes('http') ?
                                                                currentTag.bannerImage :
                                                                `/data/uploads/blogs/${currentTag.bannerImage}`; %>
                                                                <img src="<%= bannerPath %>" class="rounded border"
                                                                    style="width: 150px; height: 100px; object-fit: cover;">
                                                                <button type="button"
                                                                    class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1"
                                                                    onclick="handleImageDelete('bannerImage')">
                                                                    <i class="fa-solid fa-trash-can"></i>
                                                                </button>
                                                        </div>
                                                    </div>
                                                    <% } %>
                                                        <div id="bannerImage-file-input-wrapper"
                                                            style="<%= (currentTag && currentTag.bannerImage) ? 'display: none;' : '' %>">
                                                            <input class="form-control" type="file" name="bannerImage"
                                                                id="bannerImage">

                                                            <small class="text-muted d-block mt-1">
                                                                Recommended: 1000 × 665 pixels | Max size: 1MB
                                                            </small>
                                                            <input type="hidden" name="bannerImageRemoved"
                                                                id="bannerImageRemoved" value="false">
                                                        </div>
                                                        <% if (currentErrors.bannerImage) { %>
                                                            <small class="text-danger">
                                                                <%= currentErrors.bannerImage %>
                                                            </small>
                                                            <% } %>

                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Banner Image Alt Text</label>
                                                <input type="text" name="bannerImageAlt" class="form-control"
                                                    placeholder="Alt text"
                                                    value="<%= currentOld.bannerImageAlt || '' %>">
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Banner Title</label>
                                                <input type="text" name="bannerTitle" class="form-control"
                                                    placeholder="Banner title"
                                                    value="<%= currentOld.bannerTitle || '' %>">
                                            </div>

                                            <div class="col-lg-12 mb-3">
                                                <label class="form-label">Blog Description (Primary) <span
                                                        class="text-danger">*</span></label>
                                                <textarea name="blogDesc" class="form-control jodit-editor"
                                                    id="blogDesc"><%= currentOld.blogDesc || '' %></textarea>
                                            </div>

                                            <div class="col-lg-12 mb-3">
                                                <label class="form-label">Blog Description 1</label>
                                                <textarea name="blogDesc1" class="form-control jodit-editor"
                                                    id="blogDesc1"><%= currentOld.blogDesc1 || '' %></textarea>
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Main Image</label>
                                                <% if (currentTag && currentTag.mainImage) { %>
                                                    <div id="mainImage-preview-wrapper" class="mb-2">
                                                        <div class="position-relative d-inline-block">
                                                            <% let mainPath=currentTag.mainImage.includes('http') ?
                                                                currentTag.mainImage :
                                                                `/data/uploads/blogs/${currentTag.mainImage}`; %>
                                                                <img src="<%= mainPath %>" class="rounded border"
                                                                    style="width: 150px; height: 100px; object-fit: cover;">
                                                                <button type="button"
                                                                    class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1"
                                                                    onclick="handleImageDelete('mainImage')">
                                                                    <i class="fa-solid fa-trash-can"></i>
                                                                </button>
                                                        </div>
                                                    </div>
                                                    <% } %>
                                                        <div id="mainImage-file-input-wrapper"
                                                            style="<%= (currentTag && currentTag.mainImage) ? 'display: none;' : '' %>">
                                                            <input class="form-control" type="file" name="mainImage"
                                                                id="mainImage">
                                                            <small class="text-muted d-block mt-1">
                                                                Recommended: 1000 × 665 pixels | Max size: 1MB
                                                            </small>
                                                            <input type="hidden" name="mainImageRemoved"
                                                                id="mainImageRemoved" value="false">
                                                        </div>
                                                        <% if (currentErrors.mainImage) { %>
                                                            <small class="text-danger">
                                                                <%= currentErrors.mainImage %>
                                                            </small>
                                                            <% } %>
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Main Image Alt</label>
                                                <input type="text" name="mainImageAlt" class="form-control"
                                                    value="<%= currentOld.mainImageAlt || '' %>">
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Main Image 2</label>
                                                <% if (currentTag && currentTag.mainImage2) { %>
                                                    <div id="mainImage2-preview-wrapper" class="mb-2">
                                                        <div class="position-relative d-inline-block">
                                                            <% let mainImage2Path=currentTag.mainImage2.includes('http')
                                                                ? currentTag.mainImage2 :
                                                                `/data/uploads/blogs/${currentTag.mainImage2}`; %>
                                                                <img src="<%= mainImage2Path %>" class="rounded border"
                                                                    style="width: 150px; height: 100px; object-fit: cover;">
                                                                <button type="button"
                                                                    class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1"
                                                                    onclick="handleImageDelete('mainImage2')">
                                                                    <i class="fa-solid fa-trash-can"></i>
                                                                </button>
                                                        </div>
                                                    </div>
                                                    <% } %>
                                                        <div id="mainImage2-file-input-wrapper"
                                                            style="<%= (currentTag && currentTag.mainImage2) ? 'display: none;' : '' %>">
                                                            <input class="form-control" type="file" name="mainImage2"
                                                                id="mainImage2">
                                                            <input type="hidden" name="mainImage2Removed"
                                                                id="mainImage2Removed" value="false">
                                                        </div>
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Main Image 2 Alt</label>
                                                <input type="text" name="mainImageAlt2" class="form-control"
                                                    value="<%= currentOld.mainImageAlt2 || '' %>">
                                            </div>

                                            <div class="col-lg-12 mb-3">
                                                <label class="form-label">Blog Description 2</label>
                                                <textarea name="blogDesc2" class="form-control jodit-editor"
                                                    id="blogDesc2"><%= currentOld.blogDesc2 || '' %></textarea>
                                            </div>

                                            <div class="col-lg-12 mb-3">
                                                <label class="form-label">Call To Action</label>
                                                <textarea name="callToAction" class="form-control"
                                                    id="callToAction"><%= currentOld.callToAction || '' %></textarea>
                                            </div>

                                            <div class="col-lg-6 mb-3">
                                                <label class="form-label">Status (Visibility) <span
                                                        class="text-danger">*</span></label>
                                                <select name="show" class="form-select" required>
                                                    <option value="VISIBLE" <%=currentOld.show==='VISIBLE' ? 'selected'
                                                        : '' %>>Visible</option>
                                                    <option value="HIDDEN" <%=currentOld.show==='HIDDEN' ? 'selected'
                                                        : '' %>>Hidden</option>
                                                </select>
                                            </div>

                                            <div class="col-12 mt-3 d-flex gap-3">
                                                <a href="/blog" class="btn btn-secondary">Cancel</a>
                                                <button type="submit" id="submitBtn" class="btn btn-primary">
                                                    <%= buttonText %> Blog
                                                </button>
                                            </div>

                                        </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>

                <%- include("../partials/footer") -%>
    </div>

    <%- include("../partials/scripts") -%>

        <script>
            const form = document.getElementById('blogForm');
            const submitBtn = document.getElementById('submitBtn');

            let isSubmitting = false;

            form.addEventListener('submit', function (e) {
                if (isSubmitting) {
                    e.preventDefault();
                    return;
                }

                isSubmitting = true;
                submitBtn.disabled = true;
                submitBtn.innerHTML = 'Processing...';
            });
        </script>

        <script src="https://cdn.jsdelivr.net/npm/jodit@4.2.39/es2021/jodit.min.js"></script>
        <script>
            // Jodit Initialization
            const editors = document.querySelectorAll('.jodit-editor');
            editors.forEach(el => {
                new Jodit(el, { height: 300 });
            });

            // Image Delete Logic
            function handleImageDelete(fieldName) {
                if (confirm("Are you sure you want to remove this image?")) {
                    const preview = document.getElementById(`${fieldName}-preview-wrapper`);
                    if (preview) preview.style.display = 'none';

                    const inputWrap = document.getElementById(`${fieldName}-file-input-wrapper`);
                    if (inputWrap) inputWrap.style.display = 'block';

                    const flag = document.getElementById(`${fieldName}Removed`);
                    if (flag) flag.value = 'true';
                }
            }

            // Auto Slug Generation with user override protection
            const blogNameInput = document.getElementById('blogName');
            const slugInput = document.getElementById('blogSlug');

            let slugManuallyEdited = false;

            if (slugInput) {
                slugInput.addEventListener('input', () => {
                    slugManuallyEdited = true;
                });
            }

            if (blogNameInput && slugInput) {
                blogNameInput.addEventListener('input', function () {

                    // 🔑 stop auto update if user touched slug
                    if (slugManuallyEdited) return;

                    const slug = this.value
                        .toLowerCase()
                        .trim()
                        .replace(/[^\w ]+/g, '')
                        .replace(/\s+/g, '-');

                    slugInput.value = slug;
                });
            }
        </script>
</body>

</html>