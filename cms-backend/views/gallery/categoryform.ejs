<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gallery Categories</title>

    <%- include("../partials/links") -%>
</head>

<body>

    <div class="page-layout">


        <!-- begin::Page Header -->
        <%- include("../partials/header") -%>
            <!-- end::Page Header -->

            <!-- begin::Page Sidebar Menu -->
            <%- include("../partials/sidebar") -%>
                <!-- end:: Sidebar Menu -->

                <main class="app-wrapper">

                    <div class="container-fluid">

                        <div class="app-page-head d-flex align-items-center justify-content-between">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-0">
                                    <li class="breadcrumb-item">
                                        <a href="/">
                                            <i class="fi fi-rr-home"></i> Home
                                        </a>
                                    </li>
                                    <li class="icon-size"><i class="fa-solid fa-chevron-right"></i></li>
                                    <li class="breadcrumb-item active" aria-current="page">Category Form</li>
                                </ol>
                            </nav>
                        </div>


                        <div class="row">
                            <div class="col-12">
                                <% let actionUrl="/api/gallery/imagetag/create" ; let buttonText="Add" ; if (typeof tag
                                    !=='undefined' && tag.id) { actionUrl="/api/gallery/imagetag/update/" + tag.id;
                                    buttonText="Update" ; } %>
                                    <form action="<%= actionUrl %>" id="galleryCategoryForm" method="post">
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Category Name <span
                                                        class="text-danger">*</span></label>
                                                <input type="text" name="name" class="form-control"
                                                    value="<%= (old && old.name) ? old.name : '' %>"
                                                    placeholder="Category Name" required>
                                                <% if (errors.name) { %>
                                                    <small style="color:red">
                                                        <%= errors.name %>
                                                    </small>
                                                    <% } %>
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Status <span
                                                        class="text-danger">*</span></label>
                                                <select class="form-select" name="show" required>
                                                    <option value="">Select status</option>
                                                    <option value="VISIBLE" <%=(old && old.show==='VISIBLE' )
                                                        ? 'selected' : '' %>>Active</option>
                                                    <option value="HIDDEN" <%=(old && old.show==='HIDDEN' ) ? 'selected'
                                                        : '' %>>Inactive</option>
                                                </select>
                                                <% if (errors.show) { %>
                                                    <small style="color:red">
                                                        <%= errors.show %>
                                                    </small>
                                                    <% } %>
                                            </div>

                                            <div class="col-12">
                                                <div class="modal-footer mt-3 gap-3">
                                                    <a href="/gallerycategory" class="btn btn-subtle-danger">Cancel</a>
                                                    <button type="submit" id="submitBtn" class="btn btn-subtle-success">
                                                        <%= buttonText %>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </form>
                            </div>
                        </div>
                    </div>
                </main>

                <!-- begin::Footer -->
                <%- include("../partials/footer") -%>
                    <!-- end::Footer -->

    </div>

    <!-- begin::Page Scripts -->
    <%- include("../partials/scripts") -%>
        <!-- end::Page Scripts -->

        <script>
            const form = document.getElementById('galleryCategoryForm');
            const submitBtn = document.getElementById('submitBtn');

            let isSubmitting = false;

            form.addEventListener('submit', function (e) {
                if (isSubmitting) {
                    e.preventDefault();
                    return;
                }

                isSubmitting = true;
                submitBtn.disabled = true;
                submitBtn.innerHTML = 'Processing...';
            });
        </script>
</body>

</html>