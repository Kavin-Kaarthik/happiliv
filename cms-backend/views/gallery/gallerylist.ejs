<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gallery List</title>


    <%- include("../partials/links") -%>
</head>

<body>

    <div class="page-layout">

        <!-- begin::Page Header -->
        <%- include("../partials/header") -%>
            <!-- end::Page Header -->

            <!-- begin::Page Sidebar Menu -->
            <%- include("../partials/sidebar") -%>
                <!-- end:: Sidebar Menu -->

                <main class="app-wrapper">

                    <div class="container-fluid">

                        <div class="app-page-head d-flex align-items-center justify-content-between">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-0">
                                    <li class="breadcrumb-item">
                                        <a href="/">
                                            <i class="fi fi-rr-home"></i> Home
                                        </a>
                                    </li>
                                    <li class="icon-size"><i class="fa-solid fa-chevron-right"></i></li>
                                    <li class="breadcrumb-item active" aria-current="page">Gallery List</li>
                                </ol>
                            </nav>
                        </div>

                        <div class="row">
                            <div class="col-lg-12">
                                <div class="card overflow-hidden">
                                    <div class="card-header d-flex align-items-center justify-content-between">
                                        <h6 class="card-title mb-0">Gallery List</h6>
                                        <div>
                                            <a href="/gallerycreate" class="btn btn-primary btn-sm">
                                                <i class="fi fi-rr-plus"></i> Add New Gallery
                                            </a>
                                        </div>
                                    </div>
                                    <div class="card-body p-0 pb-2">
                                        <div id="dt_basic_wrapper"
                                            class="dt-container dt-bootstrap5 dt-empty-footer p-5">
                                            <div class="row mt-2 justify-content-between dt-layout-table">
                                                <div
                                                    class="d-md-flex justify-content-between align-items-center col-12 dt-layout-full">
                                                    <table id="dt_basic" class="table table-striped display dataTable"
                                                        aria-describedby="dt_basic_info" style="width: 100%;">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th class="minw-200px dt-orderable-asc dt-orderable-desc dt-ordering-asc"
                                                                    data-dt-column="0" rowspan="1" colspan="1"
                                                                    aria-sort="ascending">
                                                                    <div class="dt-column-header"><span
                                                                            class="dt-column-title">S No</span><span
                                                                            class="dt-column-order" role="button"
                                                                            aria-label="S No: Activate to invert sorting"
                                                                            tabindex="0"></span></div>
                                                                </th>
                                                                <th class="minw-200px dt-orderable-asc dt-orderable-desc"
                                                                    data-dt-column="2" rowspan="1" colspan="1">
                                                                    <div class="dt-column-header"><span
                                                                            class="dt-column-title">Category
                                                                            Name</span><span class="dt-column-order"
                                                                            role="button"
                                                                            aria-label="Category Name: Activate to sort"
                                                                            tabindex="0"></span></div>
                                                                </th>
                                                                <th class="minw-200px dt-orderable-asc dt-orderable-desc"
                                                                    data-dt-column="2" rowspan="1" colspan="1">
                                                                    <div class="dt-column-header"><span
                                                                            class="dt-column-title">Image
                                                                            Name</span><span class="dt-column-order"
                                                                            role="button"
                                                                            aria-label="Image Name: Activate to sort"
                                                                            tabindex="0"></span></div>
                                                                </th>
                                                                <th class="minw-200px dt-orderable-asc dt-orderable-desc"
                                                                    data-dt-column="2" rowspan="1" colspan="1">
                                                                    <div class="dt-column-header"><span
                                                                            class="dt-column-title">Image
                                                                        </span><span class="dt-column-order"
                                                                            role="button"
                                                                            aria-label="Image Name: Activate to sort"
                                                                            tabindex="0"></span></div>
                                                                </th>
                                                                <th class="minw-150px dt-orderable-asc dt-orderable-desc"
                                                                    data-dt-column="3" rowspan="1" colspan="1">
                                                                    <div class="dt-column-header"><span
                                                                            class="dt-column-title">Status</span><span
                                                                            class="dt-column-order" role="button"
                                                                            aria-label="Status: Activate to sort"
                                                                            tabindex="0"></span></div>
                                                                </th>
                                                                <th class="text-end dt-orderable-asc dt-orderable-desc"
                                                                    data-dt-column="7" rowspan="1" colspan="1">
                                                                    <div class="dt-column-header"><span
                                                                            class="dt-column-title">Action</span><span
                                                                            class="dt-column-order" role="button"
                                                                            aria-label="Action: Activate to sort"
                                                                            tabindex="0"></span></div>
                                                                </th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% if (getAllList && getAllList.length> 0) { %>
                                                                <% getAllList.forEach((item, index)=> { %>
                                                                    <tr>
                                                                        <td>
                                                                            <%= index + 1 %>
                                                                        </td>

                                                                        <td>
                                                                            <span
                                                                                class="badge bg-info-subtle text-info">
                                                                                <%= item.tag ? item.tag.name
                                                                                    : 'No Category' %>
                                                                            </span>
                                                                        </td>

                                                                        <td>
                                                                            <%= item.name %>
                                                                        </td>

                                                                        <td>
                                                                            <div class="avatar-md">
                                                                                <img src="<%= item.image %>"
                                                                                    alt="<%= item.name %>"
                                                                                    class="img-thumbnail rounded"
                                                                                    style="width: 60px; height: 45px; object-fit: cover;">
                                                                            </div>
                                                                        </td>

                                                                        <td>
                                                                            <% if(item.show==='VISIBLE' ) { %>
                                                                                <span
                                                                                    class="badge btn-subtle-success text-success">Visible</span>
                                                                                <% } else { %>
                                                                                    <span
                                                                                        class="badge btn-subtle-secondary text-primary-emphasis">Hidden</span>
                                                                                    <% } %>
                                                                        </td>

                                                                        <td>
                                                                            <div class="btn-group float-end">
                                                                                <button
                                                                                    class="btn btn-white btn-sm btn-shadow btn-icon dropdown-toggle"
                                                                                    data-bs-toggle="dropdown">
                                                                                    <i class="fi fi-rr-menu-dots"></i>
                                                                                </button>
                                                                                <ul
                                                                                    class="dropdown-menu dropdown-menu-end">
                                                                                    <li><a class="dropdown-item"
                                                                                            href="/galleryupdate/<%= item.id %>">Edit..</a>
                                                                                    </li>
                                                                                    <li>

                                                                                        <form
                                                                                            action="/api/gallery/image/delete/<%= item.id %>"
                                                                                            method="POST"
                                                                                            style="display:inline;">
                                                                                            <button type="submit"
                                                                                                class="dropdown-item text-danger"
                                                                                                onclick="return confirm('Are you sure?')">Delete</button>
                                                                                        </form>
                                                                                    </li>
                                                                                </ul>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                    <% }) %>
                                                                        <% } else { %>
                                                                            <tr>
                                                                                <td colspan="6" class="text-center">No
                                                                                    images found in gallery.</td>
                                                                            </tr>
                                                                            <% } %>
                                                        </tbody>
                                                        <tfoot></tfoot>
                                                    </table>
                                                </div>
                                            </div>
                                            <div class="dt-autosize" style="width: 100%; height: 0px;"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </main>

                <!-- begin::Footer -->
                <%- include("../partials/footer") -%>
                    <!-- end::Footer -->

    </div>

    <%- include("../partials/scripts") -%>
</body>

</html>