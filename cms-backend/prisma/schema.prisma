// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Define your database models here and run `prisma migrate dev` to create migrations for your database schema changes.
// Learn more about modeling your data in the docs: https://pris.ly/d/data-modeling

enum RecordDeleteStatus {
  ACTIVE
  DELETED
}

enum RecordActiveStatus {
  VISIBLE
  HIDDEN
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("user")
}

model GalleImageTag {
  id     Int                @id @default(autoincrement())
  name   String             @unique
  show   RecordActiveStatus @default(VISIBLE)
  status RecordDeleteStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images GalleryImage[]

  @@index([status])
  @@map("galleimagetag")
}

model GalleryImage {
  id    Int    @id @default(autoincrement())
  image String
  name  String

  tagId Int
  tag   GalleImageTag @relation(fields: [tagId], references: [id])

  link String?

  show   RecordActiveStatus @default(VISIBLE)
  status RecordDeleteStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([show])
  @@index([tagId])
  @@map("galleryimage")
}

model Blog {
  id Int @id @default(autoincrement())

  metaTitle   String? @map("meta_title")
  metaDesc    String? @map("meta_desc") @db.LongText
  metaKeyword String? @map("meta_keyword")
  slug        String  @unique

  ogTitle String? @map("og_title")
  ogDesc  String? @map("og_desc") @db.LongText
  ogImage String? @map("og_image")

  bannerImage    String? @map("blog_banner_img")
  bannerImageAlt String? @map("blog_banner_img_alt")
  bannerTitle    String? @map("blog_banner_title")

  blogName  String  @map("blog_name")
  blogDesc  String  @map("blog_desc") @db.LongText
  blogDesc1 String? @map("blog_desc1") @db.LongText
  blogDesc2 String? @map("blog_desc2") @db.LongText

  mainImage     String? @map("blog_main_img")
  mainImageAlt  String? @map("blog_main_img_alt")
  mainImage2    String? @map("blog_main_img2")
  mainImageAlt2 String? @map("blog_main_img_alt2")

  callToAction String? @map("call_to_action")

  show   RecordActiveStatus @default(VISIBLE)
  status RecordDeleteStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([show])
  @@map("blogs")
}
